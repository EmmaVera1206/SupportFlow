<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Fila superior: título y categoría -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Título de ticket"
                android:textStyle="bold"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categoría: Soporte Técnico"
                android:textSize="11sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- Descripción -->
        <TextView
            android:id="@+id/tvDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción del ticket"
            android:textSize="11sp"
            android:textColor="#555555"
            android:layout_marginTop="2dp"/>

        <!-- Fila inferior: botones y fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnDetalles"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Detalles"
                android:textSize="10sp"
                android:backgroundTint="#3F51B5"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="10dp"/>

            <Button
                android:id="@+id/btnAsignar"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Asignar Técnico"
                android:textSize="10sp"
                android:backgroundTint="#FF5722"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="10dp"
                android:layout_marginStart="6dp"/>

            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="23/02/2026"
                android:textSize="10sp"
                android:textColor="#888888"
                android:gravity="end"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>